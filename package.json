{
  "name": "git-mosaic-workspace",
  "version": "0.1.0",
  "private": true,
  "description": "Create deterministic GitHub contribution mosaic plans with preview-first safety.",
  "license": "MIT",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r --sort run build",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm pack:check",
    "clean": "node scripts/clean.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "pack": "pnpm build && node scripts/pack-workspace.mjs artifacts",
    "pack:check": "pnpm build && node scripts/check-pack.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm build && pnpm -r --sort run typecheck"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "eslint": "^9.25.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1",
    "vitest": "^3.1.2"
  }
}
